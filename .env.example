# Optional external private content repository.
# Leave unset to build with examples/content.
CONTENT_REPO_URL=git@github.com:your-name/my-blog-content.git
CONTENT_REPO_BRANCH=main

# Used only when CONTENT_REPO_URL is HTTPS. Prefer a read-only SSH deploy key in CI.
CONTENT_REPO_TOKEN=

# Optional canonical URL for local previews, custom domains or non-user GitHub Pages sites.
SITE_URL=

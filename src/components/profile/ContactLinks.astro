---
import { profile } from '../../config/content';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const github = profile.links.github;
const email = profile.links.email;
---

<div class:list={['contact-icon-links', className]} aria-label="联系方式">
  <a
    class="profile-icon-link"
    href={github.url}
    target="_blank"
    rel="noreferrer"
    aria-label="访问 GitHub"
    data-tooltip="GitHub"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 2.8a9.5 9.5 0 0 0-3 18.5c.5.1.7-.2.7-.5v-1.9c-2.8.6-3.4-1.2-3.4-1.2-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 0 1.6 1 1.6 1 .9 1.6 2.4 1.1 3 .9.1-.7.4-1.1.7-1.4-2.3-.3-4.6-1.1-4.6-4.7 0-1 .4-1.9 1-2.6-.1-.3-.4-1.3.1-2.6 0 0 .8-.3 2.7 1a9.3 9.3 0 0 1 4.9 0c1.9-1.3 2.7-1 2.7-1 .5 1.3.2 2.3.1 2.6.7.7 1 1.6 1 2.6 0 3.7-2.3 4.5-4.6 4.7.4.3.7 1 .7 2v2.7c0 .3.2.6.7.5A9.5 9.5 0 0 0 12 2.8Z" />
    </svg>
  </a>
  <a
    class="profile-icon-link"
    href={email.url}
    aria-label="发送 Email"
    data-tooltip="Email"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <rect x="3" y="5" width="18" height="14" rx="3" />
      <path d="m5 8 7 5 7-5" />
    </svg>
  </a>
</div>

---
import { profile, siteMetadata } from '../../config/content';
import ContactLinks from './ContactLinks.astro';

interface Props {
  articleCount: number;
  projectCount: number;
}

const { articleCount, projectCount } = Astro.props;
const pageViewEndpoint = siteMetadata.pageViews?.enabled ? siteMetadata.pageViews.endpoint : undefined;
---

<aside class="profile-card" aria-labelledby="profile-name">
  <div class="profile-avatar-wrap">
    <img
      class="profile-avatar"
      src={profile.avatar}
      alt={`${profile.name} 的头像`}
      width="720"
      height="720"
    />
  </div>

  <div class="profile-identity">
    <h2 id="profile-name">{profile.name}</h2>
    <div class="profile-handle">@{profile.handle}</div>
    <div class="profile-divider" aria-hidden="true"></div>
  </div>

  <div class="profile-stats" aria-label="内容统计">
    <div class="profile-stat"><strong>{articleCount}</strong><span>文章</span></div>
    <div class="profile-stat"><strong>{projectCount}</strong><span>项目</span></div>
    <div class="profile-stat">
      <strong data-total-views data-endpoint={pageViewEndpoint} aria-live="polite">—</strong>
      <span>访问</span>
    </div>
  </div>

  <ContactLinks class="profile-links" />
</aside>

<script>
  import { totalViewsUrl } from '../../lib/pageviews.mjs';

  const totalViews = document.querySelector<HTMLElement>('[data-total-views]');
  const endpoint = totalViews?.dataset.endpoint;
  if (totalViews && endpoint) {
    fetch(totalViewsUrl(endpoint))
      .then((response) => {
        if (!response.ok) throw new Error(`Page-view API returned ${response.status}.`);
        return response.json() as Promise<{ views?: number }>;
      })
      .then(({ views }) => {
        if (typeof views === 'number' && Number.isSafeInteger(views) && views >= 0) {
          totalViews.textContent = views.toLocaleString('zh-CN');
        }
      })
      .catch(() => {
        // Keep the unavailable placeholder when the optional service fails.
      });
  }
</script>

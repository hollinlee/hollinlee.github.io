---
import { profile } from '../../config/content';
import ContactLinks from './ContactLinks.astro';

interface Props {
  articleCount: number;
  projectCount: number;
  categoryCount: number;
}

const { articleCount, projectCount, categoryCount } = Astro.props;
---

<aside class="profile-card" aria-labelledby="profile-name">
  <div class="profile-avatar-wrap">
    <img
      class="profile-avatar"
      src={profile.avatar}
      alt={`${profile.name} 的头像`}
      width="720"
      height="720"
    />
  </div>

  <div class="profile-identity">
    <h2 id="profile-name">{profile.name}</h2>
    <div class="profile-handle">@{profile.handle}</div>
    <div class="profile-divider" aria-hidden="true"></div>
  </div>

  <div class="profile-stats" aria-label="内容统计">
    <div class="profile-stat"><strong>{articleCount}</strong><span>文章</span></div>
    <div class="profile-stat"><strong>{projectCount}</strong><span>项目</span></div>
    <div class="profile-stat"><strong>{categoryCount}</strong><span>分类</span></div>
  </div>

  <ContactLinks class="profile-links" />
</aside>

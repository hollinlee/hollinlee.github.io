<button class="theme-toggle" type="button" data-theme-toggle aria-label="切换到夜间模式" title="切换到夜间模式">
  <svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M20.2 15.4A8.6 8.6 0 0 1 8.6 3.8 8.7 8.7 0 1 0 20.2 15.4Z" />
  </svg>
  <svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
  </svg>
</button>

<script>
  const storageKey = 'site-theme';
  const media = matchMedia('(prefers-color-scheme: dark)');

  function currentTheme() {
    return document.documentElement.dataset.theme === 'night' ? 'night' : 'day';
  }

  function readPreference() {
    try {
      return localStorage.getItem(storageKey);
    } catch {
      return null;
    }
  }

  function savePreference(theme: 'day' | 'night') {
    try {
      localStorage.setItem(storageKey, theme);
    } catch {
      // The current document still switches theme when persistent storage is unavailable.
    }
  }

  function updateToggle(button: HTMLButtonElement) {
    const next = currentTheme() === 'night' ? '日间' : '夜间';
    const label = `切换到${next}模式`;
    button.setAttribute('aria-label', label);
    button.title = label;
  }

  function applyTheme(theme: 'day' | 'night', source: 'user' | 'system') {
    document.documentElement.dataset.theme = theme;
    document.documentElement.dataset.themeSource = source;
    document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach(updateToggle);
    dispatchEvent(new CustomEvent('site-theme-change', { detail: { theme, source } }));
  }

  document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((button) => {
    updateToggle(button);
    button.addEventListener('click', () => {
      const next = currentTheme() === 'night' ? 'day' : 'night';
      savePreference(next);
      applyTheme(next, 'user');
    });
  });

  media.addEventListener('change', (event) => {
    if (readPreference()) return;
    applyTheme(event.matches ? 'night' : 'day', 'system');
  });
</script>

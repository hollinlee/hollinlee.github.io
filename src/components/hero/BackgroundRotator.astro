---
import { backgrounds } from '../../config/content';

const serialized = JSON.stringify(backgrounds);
const initial = backgrounds.items[0];
---

<div
  class="hero-background"
  data-background-rotator
  data-backgrounds={serialized}
  style={`--hero-blur:${backgrounds.blur}px;--hero-transition:${backgrounds.transitionDuration}ms`}
  aria-hidden="true"
>
  <div
    class="hero-background-layer is-active"
    data-background-layer="0"
    style={`background-image:var(--initial-background-image, url(${JSON.stringify(initial.image)}));background-position:var(--initial-background-position, ${initial.backgroundPosition})`}
  ></div>
  <div class="hero-background-layer" data-background-layer="1"></div>
  <div class="hero-background-overlay"></div>
</div>

<script>
  import {
    BACKGROUND_STORAGE_KEY,
    advanceRotationState,
    backgroundSignature,
    createRotationState,
    parseRotationState,
  } from '../../lib/background-rotation.mjs';

  type BackgroundEntry = {
    image: string;
    textPosition: 'left' | 'right' | 'center';
    backgroundPosition: string;
  };
  type BackgroundConfig = {
    rotationInterval: number;
    transitionDuration: number;
    items: BackgroundEntry[];
  };
  type RotationState = ReturnType<typeof createRotationState>;

  document.querySelectorAll<HTMLElement>('[data-background-rotator]').forEach((root) => {
    const hero = document.querySelector<HTMLElement>('[data-background-text-target]');
    const layers = Array.from(root.querySelectorAll<HTMLElement>('[data-background-layer]'));
    const config = JSON.parse(root.dataset.backgrounds ?? '{}') as BackgroundConfig;
    const entries = config.items ?? [];
    if (entries.length === 0 || layers.length < 2) return;

    const signature = backgroundSignature(entries);
    const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)');
    let state = restoreState() ?? createRotationState(entries.length, signature, config.rotationInterval) as RotationState;
    let activeLayer = 0;
    let timer: number | undefined;
    let generation = 0;

    function storedState() {
      try {
        return sessionStorage.getItem(BACKGROUND_STORAGE_KEY);
      } catch {
        return null;
      }
    }

    function restoreState() {
      return parseRotationState(
        storedState(),
        signature,
        entries.length,
        config.rotationInterval,
      ) as RotationState | null;
    }

    function persistState() {
      try {
        sessionStorage.setItem(BACKGROUND_STORAGE_KEY, JSON.stringify(state));
      } catch {
        // Rotation remains functional when session storage is unavailable.
      }
    }

    function updateTextPosition(entry: BackgroundEntry) {
      document.documentElement.dataset.backgroundTextPosition = entry.textPosition;
      if (hero) hero.dataset.textPosition = entry.textPosition;
    }

    function setLayer(layer: HTMLElement, entry: BackgroundEntry) {
      layer.style.backgroundImage = `url(${JSON.stringify(entry.image)})`;
      layer.style.backgroundPosition = entry.backgroundPosition;
    }

    function preload(entry: BackgroundEntry) {
      return new Promise<void>((resolve) => {
        const image = new Image();
        image.onload = () => resolve();
        image.onerror = () => resolve();
        image.src = entry.image;
      });
    }

    function clearTimer() {
      if (timer !== undefined) window.clearTimeout(timer);
      timer = undefined;
    }

    function pauseTimer() {
      clearTimer();
      if (state.nextAt !== null) {
        state.remainingMs = Math.max(0, Math.min(state.nextAt - Date.now(), config.rotationInterval));
        state.nextAt = null;
        persistState();
      }
    }

    function schedule(preserveDeadline = false) {
      clearTimer();
      if (document.hidden || reducedMotion.matches || entries.length < 2) {
        pauseTimer();
        return;
      }

      const remaining = preserveDeadline && state.nextAt !== null
        ? Math.max(0, state.nextAt - Date.now())
        : state.remainingMs;
      state.remainingMs = remaining;
      if (!preserveDeadline || state.nextAt === null) state.nextAt = Date.now() + remaining;
      persistState();
      timer = window.setTimeout(() => void showNext(), remaining);
    }

    async function showNext() {
      clearTimer();
      if (document.hidden || reducedMotion.matches) {
        pauseTimer();
        return;
      }
      const nextState = advanceRotationState(
        state,
        entries.length,
        config.rotationInterval,
      ) as RotationState;
      const entry = entries[nextState.current];
      const requestGeneration = generation;
      await preload(entry);
      if (requestGeneration !== generation || document.hidden || reducedMotion.matches) return;

      const nextLayer = activeLayer === 0 ? 1 : 0;
      setLayer(layers[nextLayer], entry);
      updateTextPosition(entry);
      requestAnimationFrame(() => {
        layers[nextLayer].classList.add('is-active');
        layers[activeLayer].classList.remove('is-active');
        activeLayer = nextLayer;
        state = nextState;
        persistState();
        schedule();
      });
    }

    async function start() {
      generation += 1;
      clearTimer();
      const entry = entries[state.current];
      await preload(entry);
      setLayer(layers[activeLayer], entry);
      updateTextPosition(entry);
      persistState();
      schedule(state.nextAt !== null);
    }

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) pauseTimer();
      else schedule();
    });

    reducedMotion.addEventListener('change', () => {
      if (reducedMotion.matches) pauseTimer();
      else schedule();
    });
    void start();
  });
</script>

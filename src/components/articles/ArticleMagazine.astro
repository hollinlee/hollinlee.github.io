---
import type { CollectionEntry } from 'astro:content';
import { siteMetadata } from '../../config/content';
import { contentSlug, formatDate } from '../../lib/content';

interface Props {
  articles: CollectionEntry<'articles'>[];
}

const { articles } = Astro.props;
const emptyState = siteMetadata.emptyStates ?? {
  articlesTitle: '暂无公开文章',
  articlesDescription: '发布第一篇文章后，它会出现在这里。',
};
---

<section class="magazine-section" aria-labelledby="latest-writing-title">
  <div class="magazine-heading">
    <div>
      <span class="card-kicker">LATEST WRITING</span>
      <h2 id="latest-writing-title">最近文章</h2>
    </div>
    <a class="magazine-more" href="/archive/">查看归档 <span aria-hidden="true">→</span></a>
  </div>

  {articles.length > 0 ? (
    <div class="magazine-grid">
      {articles.map((article, index) => {
        const cover = article.data.cover;
        return (
          <article class:list={['magazine-card', { 'magazine-card-lead': index === 0, 'magazine-card-no-cover': !cover }]}>
            <a href={`/articles/${contentSlug(article.id)}/`}>
              {cover && (
                <div class="magazine-media">
                  <img
                    src={cover}
                    alt=""
                    width="1600"
                    height="900"
                    loading={index === 0 ? 'eager' : 'lazy'}
                    fetchpriority={index === 0 ? 'high' : 'auto'}
                    decoding="async"
                  />
                </div>
              )}
              <div class="magazine-copy">
                <div class="article-meta">
                  <time datetime={article.data.publishedAt.toISOString()}>{formatDate(article.data.publishedAt)}</time>
                  <span>{article.data.category}</span>
                  {article.data.tags.slice(0, 2).map((tag) => <span>#{tag}</span>)}
                </div>
                <h3>{article.data.title}</h3>
                <p>{article.data.description}</p>
              </div>
            </a>
          </article>
        );
      })}
    </div>
  ) : (
    <div class="magazine-empty">
      <span class="handwritten magazine-empty-label">Coming soon</span>
      <h3>{emptyState.articlesTitle}</h3>
      <p>{emptyState.articlesDescription}</p>
    </div>
  )}
</section>

---
import { siteMetadata } from '../../config/content';

interface Props {
  title: string;
  category: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  readingMinutes: number;
  tags: string[];
  contentId: string;
  cover?: {
    src: string;
    width: number;
    height: number;
  };
}

const {
  title,
  category,
  description,
  publishedAt,
  updatedAt,
  readingMinutes,
  tags,
  contentId,
  cover,
} = Astro.props;
const pageViewEndpoint = siteMetadata.pageViews?.enabled ? siteMetadata.pageViews.endpoint : undefined;
---

<a class="article-return" data-article-return href="/archive/">← 返回归档</a>
{cover && (
  <figure class="article-cover">
    <img
      src={cover.src}
      alt={`${title} 封面`}
      width={cover.width}
      height={cover.height}
      fetchpriority="high"
    />
  </figure>
)}
<a class="article-kind" href={`/archive/?category=${encodeURIComponent(category)}`}>{category}</a>
<h1>{title}</h1>
<p class="lede">{description}</p>
<div class="article-meta" aria-label="文章信息">
  <span class="article-meta-item">
    发布于 <time datetime={publishedAt.toISOString()}>{publishedAt.toLocaleDateString('zh-CN')}</time>
  </span>
  {updatedAt && updatedAt.valueOf() !== publishedAt.valueOf() && (
    <span class="article-meta-item">
      更新于 <time datetime={updatedAt.toISOString()}>{updatedAt.toLocaleDateString('zh-CN')}</time>
    </span>
  )}
  <span class="article-meta-item">约 {readingMinutes} 分钟读完</span>
  <span
    class="article-meta-item"
    data-page-view-slot
    data-content-id={contentId}
    data-endpoint={pageViewEndpoint}
    hidden
    aria-live="polite"
  ></span>
</div>
{tags.length > 0 && (
  <nav class="article-tags" aria-label="文章 Tags">
    {tags.map((tag) => <a href={`/archive/?tag=${encodeURIComponent(tag)}`}>#{tag}</a>)}
  </nav>
)}

<script>
  const returnLink = document.querySelector<HTMLAnchorElement>('[data-article-return]');
  if (returnLink && document.referrer) {
    try {
      const referrer = new URL(document.referrer);
      if (referrer.origin === location.origin && referrer.pathname === '/') {
        returnLink.href = '/';
        returnLink.textContent = '← 返回首页';
      }
    } catch {
      // Keep the archive fallback when the referrer is not a valid URL.
    }
  }
</script>

<script>
  import { pageViewUrl, shouldIncrementView } from '../../lib/pageviews.mjs';

  const viewSlot = document.querySelector<HTMLElement>('[data-page-view-slot]');
  const endpoint = viewSlot?.dataset.endpoint;
  const contentId = viewSlot?.dataset.contentId;
  if (viewSlot && endpoint && contentId) {
    const storageKey = `page-view:${contentId}`;
    let previousTimestamp: string | null = null;
    try {
      previousTimestamp = localStorage.getItem(storageKey);
    } catch {
      // A blocked storage API should not block reading the article.
    }
    const increment = shouldIncrementView(previousTimestamp);
    fetch(pageViewUrl(endpoint, contentId), { method: increment ? 'POST' : 'GET' })
      .then(async (response) => {
        if (!response.ok) throw new Error(`Page-view request failed with ${response.status}.`);
        return response.json() as Promise<{ views?: number }>;
      })
      .then((result) => {
        if (typeof result.views !== 'number') return;
        if (increment) {
          try {
            localStorage.setItem(storageKey, String(Date.now()));
          } catch {
            // The count is still useful when storage is unavailable.
          }
        }
        viewSlot.textContent = `${result.views} 次访问`;
        viewSlot.hidden = false;
      })
      .catch(() => {
        viewSlot.hidden = true;
      });
  }
</script>

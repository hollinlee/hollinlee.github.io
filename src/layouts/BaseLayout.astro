---
import '../styles/global.css';
import NightParticles from '../components/effects/NightParticles.astro';
import SakuraLayer from '../components/effects/SakuraLayer.astro';
import BackgroundBootstrap from '../components/hero/BackgroundBootstrap.astro';
import BackgroundRotator from '../components/hero/BackgroundRotator.astro';
import ThemeScript from '../components/theme/ThemeScript.astro';
import SiteNavigation from '../components/navigation/SiteNavigation.astro';
import { site } from '../config/site';
import { siteAgeInDays } from '../lib/content';

interface Props {
  title?: string;
  description?: string;
}

const { title = site.title, description = site.description } = Astro.props;
const canonical = new URL(Astro.url.pathname, site.url);
const path = Astro.url.pathname;
const pageContext = path === '/'
  ? 'home'
  : path === '/about/' || /^\/(articles|projects)\/[^/]+\/$/.test(path)
    ? 'reading'
    : 'index';
---

<!doctype html>
<html lang={site.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <ThemeScript />
    <BackgroundBootstrap />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={site.avatar} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={site.locale} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body data-page-context={pageContext}>
    <div class="site-environment" aria-hidden="true">
      <BackgroundRotator />
      <SakuraLayer />
      <NightParticles />
    </div>
    <SiteNavigation pathname={Astro.url.pathname} />
    <main><slot /></main>
    <footer class="site-footer">
      <div class="container">
        <p>本站已运行 {siteAgeInDays(site.siteLaunchedAt)} 天</p>
        <small>© {new Date().getFullYear()} {site.name}</small>
      </div>
    </footer>
  </body>
</html>

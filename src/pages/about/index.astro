---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../config/site';
---

<BaseLayout title="关于 — Hollin Lee" description="关于 Hollin Lee，以及这个网站存在的原因。">
  <article class="prose">
    <div class="eyebrow">关于</div>
    <h1>做有用的东西，记录背后的决策。</h1>
    <p class="lede">{site.description}</p>

    <h2>这个网站用来做什么</h2>
    <p>这里是我工作的公开索引：项目提供可以验证的成果，文章解释思考和决策，近况页面记录当前方向。</p>

    <h2>当前关注</h2>
    <ul>{site.focus.map((item) => <li>{item}</li>)}</ul>

    <h2>联系我</h2>
    <p><a href={site.github}>GitHub</a>{site.email && <> · <a href={`mailto:${site.email}`}>Email</a></>}</p>
  </article>
</BaseLayout>

---
import { getCollection, render } from 'astro:content';
import { site } from '../../config/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { contentSlug } from '../../lib/content';

const about = (await getCollection('pages')).find((page) => contentSlug(page.id) === 'about');
if (!about) throw new Error('Required published About page was not found.');
const { Content } = await render(about);
---

<BaseLayout title={`${about.data.title} — ${site.name}`} description={about.data.description || site.description}>
  <section class="about-page container">
    <header class="about-heading">
      <span class="eyebrow">ABOUT</span>
      <h1>{about.data.title}</h1>
    </header>

    <article class="about-body prose-content">
      <Content />
    </article>
  </section>
</BaseLayout>

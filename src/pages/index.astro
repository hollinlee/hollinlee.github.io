---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleMagazine from '../components/articles/ArticleMagazine.astro';
import BackgroundRotator from '../components/hero/BackgroundRotator.astro';
import NightParticles from '../components/effects/NightParticles.astro';
import SakuraLayer from '../components/effects/SakuraLayer.astro';
import ProfileCard from '../components/profile/ProfileCard.astro';
import { site } from '../config/site';

const allProjects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const allPosts = (await getCollection('posts'))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const featuredWithCovers = allPosts.filter((post) => post.data.featured && post.data.cover);
const featuredIds = new Set(featuredWithCovers.map((post) => post.id));
const posts = [...featuredWithCovers, ...allPosts.filter((post) => !featuredIds.has(post.id))].slice(0, 5);
const notes = await getCollection('notes');
---

<BaseLayout>
  <section class="anime-hero" data-text-position="left">
    <BackgroundRotator />
    <SakuraLayer />
    <NightParticles />
    <div class="container hero-inner">
      <div class="hero-copy">
        <h1>{site.title}</h1>
        <p>{site.description}</p>
      </div>

    </div>
  </section>

  <div class="home-shell">
    <div class="container home-grid">
      <ProfileCard articleCount={allPosts.length} projectCount={allProjects.length} noteCount={notes.length} />

      <div class="main-feed">
        <ArticleMagazine posts={posts} />
      </div>
    </div>
  </div>
</BaseLayout>

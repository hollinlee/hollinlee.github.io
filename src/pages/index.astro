---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BackgroundRotator from '../components/hero/BackgroundRotator.astro';
import NightParticles from '../components/effects/NightParticles.astro';
import SakuraLayer from '../components/effects/SakuraLayer.astro';
import { site } from '../config/site';
import { contentSlug, formatDate, projectStatusLabel } from '../lib/content';

const allProjects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const featuredProject = allProjects.find((item) => item.data.featured) ?? allProjects[0];
const allPosts = (await getCollection('posts'))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const posts = allPosts.slice(0, 4);
const notes = await getCollection('notes');
const nowEntries = await getCollection('now');
const nowEntry = nowEntries[0];
---

<BaseLayout>
  <section class="anime-hero" data-text-position="left">
    <BackgroundRotator />
    <SakuraLayer />
    <NightParticles />
    <div class="container hero-inner">
      <div class="hero-copy">
        <span class="hero-badge">欢迎来到我的小站</span>
        <h1>{site.title}</h1>
        <p>{site.description}</p>
        <div class="hero-actions">
          <a class="button primary" href="/blog/">开始阅读</a>
          <a class="button" href="/projects/">看看项目</a>
          <a class="button" href={site.github} target="_blank" rel="noreferrer">GitHub ↗</a>
        </div>
      </div>

    </div>
  </section>

  <div class="home-shell">
    <div class="container home-grid">
      <aside class="profile-card">
        <div class="profile-avatar-wrap">
          <img class="profile-avatar" src={site.avatar} alt={`${site.name} 的头像`} width="720" height="720" />
        </div>
        <div>
          <h2>{site.name}</h2>
          <div class="profile-handle">@{site.handle}</div>
          <div class="profile-divider"></div>
        </div>
        <div class="profile-stats" aria-label="内容统计">
          <div class="profile-stat"><strong>{allPosts.length}</strong><span>文章</span></div>
          <div class="profile-stat"><strong>{allProjects.length}</strong><span>项目</span></div>
          <div class="profile-stat"><strong>{notes.length}</strong><span>笔记</span></div>
        </div>
        <div class="profile-links">
          <a class="profile-link" href={site.github} target="_blank" rel="noreferrer">GitHub</a>
          <a class="profile-link" href="/about/">关于我</a>
        </div>
      </aside>

      <div class="main-feed">
        <section class="welcome-card glass-card">
          <div class="card-kicker">HELLO, TRAVELER</div>
          <h2>欢迎来到 {site.name} 的主页。</h2>
          <p>{site.hero.description}</p>
          <div class="focus-tags">
            {site.focus.map((item) => <span class="pill">{item}</span>)}
          </div>
        </section>

        {featuredProject && (
          <a class="widget project-banner content-card" href={`/projects/${contentSlug(featuredProject.id)}/`}>
            <div class="card-kicker">FEATURED PROJECT</div>
            <h3>{featuredProject.data.title}</h3>
            <p>{featuredProject.data.summary}</p>
            <div class="focus-tags">
              <span class="pill">{projectStatusLabel(featuredProject.data.status)}</span>
              {featuredProject.data.stack.slice(0, 4).map((item) => <span class="pill">{item}</span>)}
            </div>
          </a>
        )}

        <section class="feed-section content-card">
          <div class="feed-head">
            <div><div class="card-kicker">LATEST WRITING</div><h2>最近文章</h2></div>
            <a class="feed-more" href="/blog/">全部文章 →</a>
          </div>
          <div class="article-list">
            {posts.map((post, index) => (
              <a class="article-card" href={`/blog/${contentSlug(post.id)}/`}>
                <div>
                  <div class="article-meta"><span>{formatDate(post.data.publishedAt)}</span><span>·</span><span>{post.data.tags.slice(0, 2).join(' / ')}</span></div>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                </div>
                <div class="article-illustration" aria-hidden="true">{['✦', '☁', '⌘', '☆'][index % 4]}</div>
              </a>
            ))}
          </div>
        </section>

        <div class="widget-grid">
          <a class="widget content-card" href="/now/">
            <div class="card-kicker">NOW</div>
            <h3>最近在做什么</h3>
            {nowEntry ? (
              <>
                <p>{nowEntry.data.description}</p>
                <p style="margin-top: .9rem;">更新于 {formatDate(nowEntry.data.updatedAt)}</p>
              </>
            ) : <p>暂无公开近况。</p>}
          </a>

          <a class="widget content-card" href="/about/">
            <div class="card-kicker">ABOUT</div>
            <h3>关于这个小站</h3>
            <p>项目提供证据，文章记录思考，技术笔记保存解决过的问题。</p>
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

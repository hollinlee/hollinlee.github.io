---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';
import { contentSlug, formatDate, projectStatusLabel } from '../lib/content';

const projects = (await getCollection('projects'))
  .filter((item) => item.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <section class="hero">
    <div class="container">
      <div class="eyebrow">{site.hero.eyebrow}</div>
      <h1>{site.hero.title}</h1>
      <p class="lede">{site.hero.description}</p>
      <div class="actions">
        <a class="button primary" href="/projects/">查看项目</a>
        <a class="button" href="/blog/">阅读文章</a>
        <a class="button" href={site.github} target="_blank" rel="noreferrer">GitHub</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div><div class="eyebrow">关注方向</div><h2>我正在长期投入的领域</h2></div>
      </div>
      <div class="grid">
        {site.focus.map((focus, index) => (
          <div class="card">
            <span class="meta">0{index + 1}</span>
            <h3>{focus}</h3>
            <p>通过真实项目、持续记录和反复迭代，建立可以验证的理解与能力。</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div><div class="eyebrow">代表作品</div><h2>项目</h2></div>
        <a href="/projects/">查看全部 →</a>
      </div>
      <div class="grid">
        {projects.map((project) => (
          <a class="card" href={`/projects/${contentSlug(project.id)}/`}>
            <span class="pill">{projectStatusLabel(project.data.status)}</span>
            <h3>{project.data.title}</h3>
            <p>{project.data.summary}</p>
            <div class="card-footer">
              {project.data.stack.slice(0, 4).map((item) => <span class="pill">{item}</span>)}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div><div class="eyebrow">最近更新</div><h2>文章</h2></div>
        <a href="/blog/">查看全部 →</a>
      </div>
      <div class="list">
        {posts.map((post) => (
          <a class="list-item" href={`/blog/${contentSlug(post.id)}/`}>
            <div class="meta">{formatDate(post.data.publishedAt)}</div>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container card">
      <div class="eyebrow">最近在做</div>
      <h2>持续构建、学习，并记录过程。</h2>
      <p class="lede">网站是我的公开索引：项目提供证据，文章记录过程和技术决策。</p>
      <div class="actions"><a class="button" href="/now/">查看我的近况 →</a></div>
    </div>
  </section>
</BaseLayout>

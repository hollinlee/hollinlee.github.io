---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';
import { contentSlug, formatDate, projectStatusLabel } from '../lib/content';

const projects = (await getCollection('projects'))
  .filter((item) => item.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
const featuredProject = projects[0];
const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
const nowEntries = await getCollection('now');
const nowEntry = nowEntries[0];
---

<BaseLayout>
  <section class="profile-hero">
    <div class="container hero-grid">
      <div class="identity-panel">
        <div>
          <div class="identity-topline">
            <span>PROFILE / HOLLINLEE</span>
            <span>BUILDING IN PUBLIC · 2026</span>
          </div>
          <h1>你好，<span>我是 Hollin。</span></h1>
          <p class="hero-lede">{site.hero.description}</p>
          <div class="hero-tags">
            <span class="tag">@{site.handle}</span>
            <span class="tag">{site.nickname}</span>
            <span class="tag">{site.role}</span>
          </div>
        </div>
        <div class="hero-actions">
          <a class="button primary" href="/projects/">查看代表项目</a>
          <a class="button" href="/blog/">阅读文章</a>
          <a class="button" href={site.github} target="_blank" rel="noreferrer">GitHub ↗</a>
        </div>
      </div>

      <div class="avatar-panel" aria-label="Hollin 的个人头像">
        <img src={site.avatar} alt="Hollin 使用的猫耳动漫头像" width="720" height="720" />
        <div class="avatar-stamp top">
          <strong><span class="status-dot"></span>正在构建</strong>
          <span>AI TOOLS / COMPILER / SYSTEMS</span>
        </div>
        <div class="avatar-stamp bottom">
          <strong>{site.nickname}</strong>
          <span>PERSONAL MARK · 01</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div><div class="section-kicker">PERSONAL INDEX</div><h2>我的工作与近况</h2></div>
        <a class="section-link" href="/about/">了解更多 →</a>
      </div>

      <div class="bento">
        {featuredProject && (
          <a class="bento-item project" href={`/projects/${contentSlug(featuredProject.id)}/`}>
            <div class="bento-top">
              <div><div class="section-kicker">代表项目</div><h3>{featuredProject.data.title}</h3></div>
              <span class="bento-number">01 / PROJECT</span>
            </div>
            <p>{featuredProject.data.summary}</p>
            <div class="bento-footer">
              <span class="pill">{projectStatusLabel(featuredProject.data.status)}</span>
              {featuredProject.data.stack.map((item) => <span class="pill">{item}</span>)}
            </div>
          </a>
        )}

        <a class="bento-item now" href="/now/">
          <div class="bento-top">
            <div><div class="section-kicker">NOW</div><h3>最近在做什么</h3></div>
            <span class="bento-number">02 / STATUS</span>
          </div>
          <p>重建个人主页与内容系统，持续改进 AI developer tooling，并学习编译器与系统编程。</p>
          {nowEntry && <div class="bento-footer"><span class="pill">更新于 {formatDate(nowEntry.data.updatedAt)}</span></div>}
        </a>

        <div class="bento-item writing">
          <div class="bento-top">
            <div><div class="section-kicker">WRITING</div><h3>最近文章</h3></div>
            <a class="section-link" href="/blog/">全部文章 →</a>
          </div>
          <div class="writing-list">
            {posts.map((post) => (
              <a class="writing-row" href={`/blog/${contentSlug(post.id)}/`}>
                <time>{formatDate(post.data.publishedAt)}</time>
                <strong>{post.data.title}</strong>
                <span>↗</span>
              </a>
            ))}
          </div>
        </div>

        <div class="bento-item profile">
          <div class="bento-top">
            <div><div class="section-kicker">PROFILE DATA</div><h3>个人档案</h3></div>
            <span class="bento-number">03 / ME</span>
          </div>
          <ul class="profile-list">
            <li><span>身份</span><small>{site.role}</small></li>
            <li><span>昵称</span><small>{site.nickname}</small></li>
            <li><span>关注</span><small>Agent / Compiler / Systems</small></li>
            <li><span>输出</span><small>项目、文章与技术笔记</small></li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { contentSlug } from '../../lib/content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Projects — Hollin Lee" description="Selected projects and engineering case studies.">
  <section class="prose">
    <div class="eyebrow">Selected work</div>
    <h1>Projects that show the work.</h1>
    <p class="lede">Each project records the problem, decisions, implementation and lessons—not just a repository link.</p>
    <div class="grid">
      {projects.map((project) => (
        <a class="card" href={`/projects/${contentSlug(project.id)}/`}>
          <span class="pill">{project.data.status}</span>
          <h3>{project.data.title}</h3>
          <p>{project.data.summary}</p>
          <div class="card-footer">
            {project.data.stack.map((item) => <span class="pill">{item}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

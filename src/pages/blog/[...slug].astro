---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../config/site';
import { contentSlug, formatDate } from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({ params: { slug: contentSlug(post.id) }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — ${site.name}`} description={post.data.description}>
  <article class="prose">
    <div class="eyebrow">文章</div>
    <h1>{post.data.title}</h1>
    <p class="lede">{post.data.description}</p>
    <p class="meta">发布于 {formatDate(post.data.publishedAt)}</p>
    <Content />
  </article>
</BaseLayout>

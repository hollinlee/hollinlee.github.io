---
import { getCollection, render } from 'astro:content';
import ArticleHeader from '../../components/articles/ArticleHeader.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../config/site';
import { contentId, contentSlug, estimateReadingMinutes } from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({ params: { slug: contentSlug(post.id) }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — ${site.name}`} description={post.data.description}>
  <article class="prose">
    <ArticleHeader
      kind="文章"
      title={post.data.title}
      description={post.data.description}
      publishedAt={post.data.publishedAt}
      updatedAt={post.data.updatedAt}
      readingMinutes={estimateReadingMinutes(post.body ?? '')}
      tags={post.data.tags}
      contentId={contentId('post', post.id)}
    />
    <Content />
    <div data-comments-slot aria-label="评论"></div>
  </article>
</BaseLayout>

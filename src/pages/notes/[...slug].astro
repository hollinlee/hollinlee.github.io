---
import { getCollection, render } from 'astro:content';
import ArticleHeader from '../../components/articles/ArticleHeader.astro';
import GiscusComments from '../../components/articles/GiscusComments.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../config/site';
import { contentId, contentSlug, estimateReadingMinutes } from '../../lib/content';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({ params: { slug: contentSlug(note.id) }, props: { note } }));
}

const { note } = Astro.props;
const { Content } = await render(note);
---

<BaseLayout title={`${note.data.title} — ${site.name}`} description={note.data.description}>
  <article class="prose">
    <ArticleHeader
      kind="技术笔记"
      title={note.data.title}
      description={note.data.description}
      publishedAt={note.data.publishedAt}
      updatedAt={note.data.updatedAt}
      readingMinutes={estimateReadingMinutes(note.body ?? '')}
      tags={note.data.tags}
      contentId={contentId('note', note.id)}
    />
    <Content />
    {note.data.comments && <GiscusComments />}
  </article>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import { site } from '../../config/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { contentSlug } from '../../lib/content';

type ArchiveItem = {
  id: string;
  type: '文章' | '笔记';
  title: string;
  description: string;
  publishedAt: Date;
  tags: string[];
  href: string;
};

const posts: ArchiveItem[] = (await getCollection('posts')).map((post) => ({
  id: `post-${post.id}`,
  type: '文章',
  title: post.data.title,
  description: post.data.description,
  publishedAt: post.data.publishedAt,
  tags: post.data.tags,
  href: `/blog/${contentSlug(post.id)}/`,
}));
const notes: ArchiveItem[] = (await getCollection('notes')).map((note) => ({
  id: `note-${note.id}`,
  type: '笔记',
  title: note.data.title,
  description: note.data.description,
  publishedAt: note.data.publishedAt,
  tags: note.data.tags,
  href: `/notes/${contentSlug(note.id)}/`,
}));
const items = [...posts, ...notes].sort((a, b) => b.publishedAt.valueOf() - a.publishedAt.valueOf());
const tags = [...new Set(items.flatMap((item) => item.tags))].sort((a, b) => a.localeCompare(b, 'zh-CN'));
const years = new Map<number, Map<number, ArchiveItem[]>>();

for (const item of items) {
  const year = item.publishedAt.getFullYear();
  const month = item.publishedAt.getMonth() + 1;
  if (!years.has(year)) years.set(year, new Map());
  const months = years.get(year)!;
  if (!months.has(month)) months.set(month, []);
  months.get(month)!.push(item);
}

const dayFormatter = new Intl.DateTimeFormat('zh-CN', { day: '2-digit' });
---

<BaseLayout title={`归档 — ${site.name}`} description="按 Tag 和时间浏览公开文章与笔记。">
  <section class="archive-page container">
    <header class="archive-intro">
      <span class="eyebrow">ARCHIVE</span>
      <h1>归档</h1>
      <p>按 Tag 筛选，下方按时间倒序排列文章和笔记。</p>
    </header>

    <div class="tag-filter" role="group" aria-label="按 Tag 筛选归档">
      <button type="button" class="tag-filter-button is-active" data-tag-value="" aria-pressed="true">全部</button>
      {tags.map((tag) => (
        <button type="button" class="tag-filter-button" data-tag-value={tag} aria-pressed="false">#{tag}</button>
      ))}
    </div>
    <p class="archive-status" data-archive-status aria-live="polite">共 {items.length} 条内容</p>

    {items.length > 0 ? (
      <div class="archive-timeline" data-archive-timeline>
        {[...years.entries()].map(([year, months]) => (
          <section class="archive-year" data-archive-year>
            <h2>{year}</h2>
            <div class="archive-months">
              {[...months.entries()].map(([month, monthItems]) => (
                <section class="archive-month" data-archive-group>
                  <h3>{month} 月</h3>
                  <div class="archive-items">
                    {monthItems.map((item) => (
                      <article class="archive-item" data-archive-item data-tags={JSON.stringify(item.tags)}>
                        <time datetime={item.publishedAt.toISOString()}>{dayFormatter.format(item.publishedAt)} 日</time>
                        <a href={item.href}>
                          <div class="archive-item-heading">
                            <span class="archive-type">{item.type}</span>
                            <h4>{item.title}</h4>
                          </div>
                          <p>{item.description}</p>
                          {item.tags.length > 0 && (
                            <div class="archive-item-tags" aria-label="Tags">
                              {item.tags.map((tag) => <span>#{tag}</span>)}
                            </div>
                          )}
                        </a>
                      </article>
                    ))}
                  </div>
                </section>
              ))}
            </div>
          </section>
        ))}
      </div>
    ) : (
      <div class="magazine-empty">
        <span class="handwritten magazine-empty-label">Empty archive</span>
        <h3>暂无公开内容</h3>
        <p>发布文章或笔记后，它们会按时间出现在这里。</p>
      </div>
    )}
  </section>
</BaseLayout>

<script>
  const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-tag-value]'));
  const items = Array.from(document.querySelectorAll<HTMLElement>('[data-archive-item]'));
  const groups = Array.from(document.querySelectorAll<HTMLElement>('[data-archive-group]'));
  const years = Array.from(document.querySelectorAll<HTMLElement>('[data-archive-year]'));
  const status = document.querySelector<HTMLElement>('[data-archive-status]');
  const validTags = new Set(buttons.map((button) => button.dataset.tagValue ?? '').filter(Boolean));

  function selectedFromUrl() {
    const requested = new URL(location.href).searchParams.get('tag') ?? '';
    return validTags.has(requested) ? requested : '';
  }

  function updateUrl(tag: string, replace = false) {
    const url = new URL(location.href);
    if (tag) url.searchParams.set('tag', tag);
    else url.searchParams.delete('tag');
    history[replace ? 'replaceState' : 'pushState']({}, '', url);
  }

  function applyFilter(tag: string) {
    let visibleCount = 0;
    for (const item of items) {
      const itemTags = JSON.parse(item.dataset.tags ?? '[]') as string[];
      const visible = !tag || itemTags.includes(tag);
      item.hidden = !visible;
      if (visible) visibleCount += 1;
    }

    for (const group of groups) {
      group.hidden = !group.querySelector('[data-archive-item]:not([hidden])');
    }
    for (const year of years) {
      year.hidden = !year.querySelector('[data-archive-group]:not([hidden])');
    }
    for (const button of buttons) {
      const active = (button.dataset.tagValue ?? '') === tag;
      button.classList.toggle('is-active', active);
      button.setAttribute('aria-pressed', String(active));
    }
    if (status) status.textContent = tag ? `#${tag}：${visibleCount} 条内容` : `共 ${visibleCount} 条内容`;
  }

  for (const button of buttons) {
    button.addEventListener('click', () => {
      const value = button.dataset.tagValue ?? '';
      const current = buttons.find((candidate) => candidate.getAttribute('aria-pressed') === 'true')?.dataset.tagValue ?? '';
      const next = value && value === current ? '' : value;
      applyFilter(next);
      updateUrl(next);
    });
  }

  addEventListener('popstate', () => applyFilter(selectedFromUrl()));

  const initial = selectedFromUrl();
  applyFilter(initial);
  const requested = new URL(location.href).searchParams.get('tag') ?? '';
  if (requested && requested !== initial) updateUrl('', true);
</script>

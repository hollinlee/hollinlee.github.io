---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../lib/content';

const entries = await getCollection('now');
const entry = entries[0];
if (!entry) throw new Error('No published Now entry found.');
const { Content } = await render(entry);
---

<BaseLayout title="近况 — Hollin Lee" description={entry.data.description}>
  <article class="prose">
    <div class="eyebrow">近况</div>
    <h1>我最近在做什么。</h1>
    <p class="meta">更新于 {formatDate(entry.data.updatedAt)}</p>
    <Content />
  </article>
</BaseLayout>
